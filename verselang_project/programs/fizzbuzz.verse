book Numbers
    place field flavor plain
    go field
    let "i" taste nogods
    while "i" less nocovet
        "i" divine noname is 0 judges
            write "Fizz"
        else
            "i" divine honor is 0 judges
                write "Buzz"
            else
                write "i"
            end
        end
        let "i" taste "i" sweet nogods
    end
endbook